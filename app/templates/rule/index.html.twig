{% extends 'base.html.twig' %}

{% block title %}{{ 'rules.title'|trans({}, 'common') }}{% endblock %}

{% block body %}
    <section class="max-w-[1000px] mx-auto px-10 py-16">
        <h1 class="font-russo text-4xl mb-2">{{ 'rules.title'|trans({}, 'common') }}</h1>
        <p class="text-gray-light mb-8">{{ 'rules.subtitle'|trans({}, 'common') }}</p>

        {% if rule %}
            <div class="bg-bg-card rounded-lg border border-metal-dark overflow-hidden">
                <div class="px-6 py-4 border-b border-metal-dark">
                    <span class="text-gray-mid text-sm">
                        {{ 'rules.last_update'|trans({}, 'common') }} {{ rule.createdAt|format_datetime('long', 'short', locale=app.request.locale) }}
                    </span>
                </div>

                <div class="px-6 py-8 prose prose-invert prose-lg max-w-none
                            prose-headings:font-russo prose-headings:text-white
                            prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl
                            prose-p:text-gray-light prose-p:leading-relaxed
                            prose-a:text-turquoise prose-a:no-underline hover:prose-a:underline
                            prose-strong:text-white
                            prose-ul:text-gray-light prose-ol:text-gray-light
                            prose-li:marker:text-orange">
                    {{ rule.content|raw }}
                </div>
            </div>
        {% else %}
            <div class="bg-bg-card rounded-lg p-8 border border-metal-dark text-center">
                <p class="text-gray-mid">{{ 'rules.no_rules'|trans({}, 'common') }}</p>
            </div>
        {% endif %}
    </section>
{% endblock %}
