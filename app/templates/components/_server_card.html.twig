{#
    Server Card Component
    @param server Server entity
    @param info array{online: bool, name: string|null, playerCount: int, maxPlayers: int, currentMap: string|null, players: array<string>, error: string|null}
#}
<div class="server-card bg-bg-card rounded-lg overflow-hidden border border-metal-dark
            hover:-translate-y-1 hover:border-turquoise hover:shadow-[0_10px_30px_rgba(0,212,212,0.2)]
            transition-all duration-300"
     data-server-id="{{ server.id }}">
    {# Header #}
    <div class="bg-metal-dark px-5 py-3 flex justify-between items-center">
        <span class="server-name font-russo text-sm truncate" title="{{ (info.name ?? server.name)|tm_strip }}">
            {{ (info.name ?? server.name)|tm_color }}
        </span>
        <span class="server-status text-[11px] font-semibold px-2.5 py-1 rounded-full uppercase tracking-wider flex-shrink-0
                     {% if info.online %}bg-green-500/20 text-green-400{% else %}bg-red-500/20 text-red-400{% endif %}">
            {% if info.online %}{{ 'server.status.online'|trans({}, 'common') }}{% else %}{{ 'server.status.offline'|trans({}, 'common') }}{% endif %}
        </span>
    </div>

    {# Body #}
    <div class="p-5">
        {# Current map #}
        <div class="server-map-container mb-4 flex items-center gap-2 text-sm">
            <span class="text-gray-mid">{{ 'server.current_map'|trans({}, 'common') }} :</span>
            {% if info.online and info.currentMap %}
                <span class="server-map truncate" title="{{ info.currentMap|tm_strip }}">{{ info.currentMap|tm_color }}</span>
            {% else %}
                <span class="server-map text-gray-mid italic">{{ 'server.no_map'|trans({}, 'common') }}</span>
            {% endif %}
        </div>

        {# Player list #}
        <div class="mb-4 p-3 bg-metal-dark/50 rounded">
            <div class="flex items-center justify-between mb-2">
                <span class="text-xs text-gray-mid uppercase tracking-wider">{{ 'server.players'|trans({}, 'common') }}</span>
                <span class="text-xs">
                    <span class="server-player-count font-semibold text-turquoise">{{ info.playerCount }}</span>
                    <span class="text-gray-mid">/ <span class="server-max-players">{{ info.maxPlayers }}</span></span>
                </span>
            </div>
            <div class="server-players-list">
                {% if info.online and info.players|length > 0 %}
                    <div class="flex flex-wrap gap-1">
                        {% for player in info.players|slice(0, 8) %}
                            <span class="text-xs px-2 py-0.5 bg-metal-mid rounded text-gray-light">{{ player|tm_color }}</span>
                        {% endfor %}
                        {% if info.players|length > 8 %}
                            <span class="text-xs px-2 py-0.5 text-gray-mid">+{{ info.players|length - 8 }}</span>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="text-xs text-gray-mid italic">{{ 'server.no_players'|trans({}, 'common') }}</div>
                {% endif %}
            </div>
        </div>

        {# Actions #}
        <div class="flex gap-2">
            {% if server.login %}
                <a href="tmtp://#join={{ server.login }}"
                   class="server-join-btn flex-1 text-center px-4 py-2 text-sm font-semibold rounded
                          transition-all duration-300 no-underline
                          {% if info.online %}
                              bg-gradient-to-br from-turquoise to-turquoise-dark text-bg-dark
                              hover:shadow-[0_4px_15px_rgba(0,212,212,0.4)]
                          {% else %}
                              bg-metal-mid text-gray-mid cursor-not-allowed
                          {% endif %}">
                    {{ 'server.join'|trans({}, 'common') }}
                </a>
                {% if server.relayLogin %}
                    <a href="tmtp://#spectate={{ server.relayLogin }}"
                       class="px-3 py-2 text-sm rounded border border-metal-mid
                              transition-all duration-300 bg-metal-dark text-gray-mid no-underline
                              hover:border-turquoise hover:text-turquoise"
                       title="{{ 'server.relay'|trans({}, 'common') }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </a>
                {% endif %}
                <a href="tmtp://#addfavourite={{ server.login }}"
                   class="px-3 py-2 text-sm rounded border border-metal-mid
                          transition-all duration-300 bg-metal-dark text-gray-mid no-underline
                          hover:border-yellow-500 hover:text-yellow-400"
                   title="{{ 'server.favorite'|trans({}, 'common') }}">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                    </svg>
                </a>
            {% endif %}
        </div>
    </div>
</div>
