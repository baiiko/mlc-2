{#
    Input Component (Single Responsibility: only handles input rendering)
    @param name string - Input name
    @param label string - Label text
    @param type string - Input type (default: text)
    @param placeholder string|null - Placeholder text
    @param required bool - Is required (default: false)
    @param value string|null - Current value
    @param error string|null - Error message
    @param help string|null - Help text
    @param icon string|null - Icon (emoji or text)
#}
{% set type = type|default('text') %}
{% set required = required|default(false) %}

<div class="mb-5">
    <label for="{{ name }}" class="block text-sm font-medium text-gray-light mb-2">
        {{ label }}
        {% if required %}<span class="text-orange">*</span>{% endif %}
    </label>

    <div class="relative">
        {% if icon is defined and icon %}
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-mid">{{ icon }}</span>
        {% endif %}

        <input
            type="{{ type }}"
            id="{{ name }}"
            name="{{ name }}"
            {% if placeholder is defined %}placeholder="{{ placeholder }}"{% endif %}
            {% if value is defined and value %}value="{{ value }}"{% endif %}
            {% if required %}required{% endif %}
            class="w-full px-4 py-3 {{ icon is defined and icon ? 'pl-12' : '' }}
                   bg-metal-dark border rounded-lg
                   text-white placeholder-gray-mid
                   focus:outline-none focus:ring-2 focus:ring-orange focus:border-transparent
                   transition-all duration-300
                   {{ error is defined and error ? 'border-red-500' : 'border-metal-light' }}"
        >
    </div>

    {% if error is defined and error %}
        <p class="mt-2 text-sm text-red-500">{{ error }}</p>
    {% elseif help is defined and help %}
        <p class="mt-2 text-sm text-gray-mid">{{ help }}</p>
    {% endif %}
</div>
