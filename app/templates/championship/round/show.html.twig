{% extends 'base.html.twig' %}

{% block title %}{{ round.name }} - {{ season.name }}{% endblock %}

{% block body %}
    <section class="max-w-[1400px] mx-auto px-10 py-16">
        {# Header #}
        <div class="mb-8">
            <a href="{{ path('app_championship_season_show', {slug: season.slug}) }}" class="text-gray-mid hover:text-turquoise transition-colors mb-4 inline-block">
                &larr; {{ season.name }}
            </a>
            <div class="flex items-center gap-4 flex-wrap">
                <h1 class="font-russo text-4xl">{{ round.name }}</h1>
                {% if round.isActive %}
                    <span class="px-3 py-1 bg-green-500/20 text-green-400 text-sm rounded uppercase">{{ 'championship.active'|trans({}, 'championship') }}</span>
                {% endif %}
            </div>
        </div>

        {# Tabs #}
        {% if round.phases is not empty or round.maps is not empty %}
            <div class="mb-6">
                <div class="flex flex-wrap gap-2 border-b border-metal-dark pb-4">
                    {# Phase tabs #}
                    {% for phase in round.phases %}
                        <button
                            class="round-tab px-5 py-3 rounded-t font-semibold text-sm uppercase tracking-wider transition-all {{ loop.first ? 'active bg-orange text-white shadow-[0_2px_10px_rgba(255,140,0,0.4)]' : 'bg-bg-card text-gray-light hover:text-white hover:bg-metal-dark' }}"
                            data-tab="phase-{{ phase.id }}"
                        >
                            {{ phase.type.translationKey|trans({}, 'championship') }}
                            {% if not phase.isPlayable %}
                                <span class="ml-1 text-xs">({{ registrations|length }})</span>
                            {% endif %}
                        </button>
                    {% endfor %}

                    {# Separator #}
                    <div class="flex-1"></div>

                    {# Maps tab #}
                    <button
                        class="round-tab px-5 py-3 rounded-t font-semibold text-sm uppercase tracking-wider transition-all bg-bg-card text-gray-light hover:text-white hover:bg-metal-dark"
                        data-tab="maps"
                    >
                        {{ 'championship.maps'|trans({}, 'championship') }}
                        <span class="ml-1 text-xs">({{ round.maps|length }})</span>
                    </button>
                </div>
            </div>

            {# Phase content #}
            {% for phase in round.phases %}
                <div class="tab-content {{ loop.first ? '' : 'hidden' }}" data-tab="phase-{{ phase.id }}">

                    {% if not phase.isPlayable %}
                        {# Registration phase #}
                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                            <div class="lg:col-span-1">
                                <div class="bg-bg-card rounded-lg p-6 border border-metal-dark">
                                    <h2 class="font-russo text-xl text-orange mb-4">{{ 'championship.registration'|trans({}, 'championship') }}</h2>

                                    <div class="mb-4">
                                        <div class="text-sm text-gray-light mb-1">{{ 'championship.registration_period'|trans({}, 'championship') }}</div>
                                        <div class="text-white">
                                            {{ phase.startAt|date('d/m/Y H:i') }} - {{ phase.endAt|date('d/m/Y H:i') }}
                                        </div>
                                    </div>

                                    {% if round.isRegistrationOpen %}
                                        {% if player %}
                                            {% if playerRegistration %}
                                                <div class="p-4 bg-green-500/20 border border-green-500 rounded text-green-400 text-center mb-4">
                                                    {{ 'championship.already_registered'|trans({}, 'championship') }}
                                                </div>
                                                <form method="post" action="{{ path('app_championship_update_availability', {id: round.id}) }}">
                                                    <div class="mb-4">
                                                        <p class="text-sm text-gray-light mb-3">{{ 'championship.update_availability'|trans({}, 'championship') }}</p>
                                                        <div class="space-y-2">
                                                            <label class="flex items-center gap-2 cursor-pointer">
                                                                <input type="checkbox" name="availableSemiFinal1" value="1" {{ playerRegistration.availableSemiFinal1 ? 'checked' : '' }} class="w-4 h-4 accent-orange">
                                                                <span class="text-sm">{{ 'championship.available_semi_final_1'|trans({}, 'championship') }}</span>
                                                            </label>
                                                            <label class="flex items-center gap-2 cursor-pointer">
                                                                <input type="checkbox" name="availableSemiFinal2" value="1" {{ playerRegistration.availableSemiFinal2 ? 'checked' : '' }} class="w-4 h-4 accent-orange">
                                                                <span class="text-sm">{{ 'championship.available_semi_final_2'|trans({}, 'championship') }}</span>
                                                            </label>
                                                            <label class="flex items-center gap-2 cursor-pointer">
                                                                <input type="checkbox" name="availableFinal" value="1" {{ playerRegistration.availableFinal ? 'checked' : '' }} class="w-4 h-4 accent-orange">
                                                                <span class="text-sm">{{ 'championship.available_final'|trans({}, 'championship') }}</span>
                                                            </label>
                                                        </div>
                                                    </div>
                                                    <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 bg-transparent text-white border-2 border-metal-light hover:border-turquoise hover:text-turquoise">
                                                        {{ 'championship.save_availability'|trans({}, 'championship') }}
                                                    </button>
                                                </form>
                                            {% else %}
                                                <form method="post" action="{{ path('app_championship_register', {id: round.id}) }}">
                                                    <div class="mb-4">
                                                        <p class="text-sm text-gray-light mb-3">{{ 'championship.availability'|trans({}, 'championship') }}</p>
                                                        <div class="space-y-2">
                                                            <label class="flex items-center gap-2 cursor-pointer">
                                                                <input type="checkbox" name="availableSemiFinal1" value="1" checked class="w-4 h-4 accent-orange">
                                                                <span class="text-sm">{{ 'championship.available_semi_final_1'|trans({}, 'championship') }}</span>
                                                            </label>
                                                            <label class="flex items-center gap-2 cursor-pointer">
                                                                <input type="checkbox" name="availableSemiFinal2" value="1" checked class="w-4 h-4 accent-orange">
                                                                <span class="text-sm">{{ 'championship.available_semi_final_2'|trans({}, 'championship') }}</span>
                                                            </label>
                                                            <label class="flex items-center gap-2 cursor-pointer">
                                                                <input type="checkbox" name="availableFinal" value="1" checked class="w-4 h-4 accent-orange">
                                                                <span class="text-sm">{{ 'championship.available_final'|trans({}, 'championship') }}</span>
                                                            </label>
                                                        </div>
                                                    </div>
                                                    <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 bg-gradient-to-br from-orange to-orange-dark text-white shadow-[0_4px_15px_rgba(255,140,0,0.4)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(255,140,0,0.5)]">
                                                        {{ 'championship.register_now'|trans({}, 'championship') }}
                                                    </button>
                                                </form>
                                            {% endif %}
                                        {% else %}
                                            <a href="{{ path('app_login') }}" class="w-full inline-flex items-center justify-center px-6 py-3 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 bg-transparent text-white border-2 border-metal-light hover:border-turquoise hover:text-turquoise">
                                                {{ 'championship.login_to_register'|trans({}, 'championship') }}
                                            </a>
                                        {% endif %}
                                    {% else %}
                                        <div class="p-4 bg-metal-dark rounded text-gray-mid text-center">
                                            {{ 'championship.registration_closed'|trans({}, 'championship') }}
                                        </div>
                                    {% endif %}

                                    <div class="mt-4 text-center text-sm text-gray-light">
                                        {{ registrations|length }} {{ 'championship.registered_players'|trans({}, 'championship') }}
                                    </div>
                                </div>
                            </div>

                            <div class="lg:col-span-2">
                                <div class="bg-bg-card rounded-lg p-6 border border-metal-dark">
                                    <h2 class="font-russo text-xl text-orange mb-4">{{ 'championship.registered_list'|trans({}, 'championship') }}</h2>

                                    {% if registrations is empty %}
                                        <p class="text-gray-mid">{{ 'championship.no_registrations'|trans({}, 'championship') }}</p>
                                    {% else %}
                                        {# Legend #}
                                        <div class="flex flex-wrap gap-4 mb-4 text-xs text-gray-light">
                                            <span class="flex items-center gap-1"><span class="w-3 h-3 bg-green-500 rounded-sm"></span> {{ 'championship.availability_full'|trans({}, 'championship') }}</span>
                                            <span class="flex items-center gap-1"><span class="w-3 h-3 bg-orange rounded-sm"></span> {{ 'championship.availability_partial'|trans({}, 'championship') }}</span>
                                            <span class="flex items-center gap-1"><span class="w-3 h-3 bg-red-500 rounded-sm"></span> {{ 'championship.availability_none'|trans({}, 'championship') }}</span>
                                        </div>

                                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2">
                                            {% for registration in registrations %}
                                                {% set isFullyAvailable = registration.availableSemiFinal1 and registration.availableSemiFinal2 and registration.availableFinal %}
                                                {% set isForfait = not registration.availableSemiFinal1 and not registration.availableSemiFinal2 and not registration.availableFinal %}
                                                {% set borderColor = isForfait ? 'border-l-red-500' : (isFullyAvailable ? 'border-l-green-500' : 'border-l-orange') %}

                                                <div class="flex items-center justify-between p-3 bg-bg-dark rounded border-l-4 {{ borderColor }}">
                                                    <div class="flex items-center gap-2">
                                                        <span class="tm-colors">{{ registration.player.pseudo|tm_color|raw }}</span>
                                                        {% if not isForfait and not isFullyAvailable %}
                                                            <span class="text-[10px] text-gray-mid">
                                                                {% if registration.availableSemiFinal1 %}D1{% endif %}
                                                                {% if registration.availableSemiFinal2 %}D2{% endif %}
                                                                {% if registration.availableFinal %}F{% endif %}
                                                            </span>
                                                        {% endif %}
                                                    </div>
                                                    {% if registration.team %}
                                                        <span class="text-xs text-gray-light tm-colors">{{ registration.team.tag|tm_color|raw }}</span>
                                                    {% endif %}
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                    {% else %}
                        {# Playable phase (Qualification, Semi, Final) #}
                        <div class="bg-bg-card rounded-lg p-6 border border-metal-dark">
                            <div class="flex items-center justify-between mb-6">
                                <h2 class="font-russo text-xl text-orange">{{ phase.type.label }}</h2>
                                <div class="text-sm text-gray-light">
                                    {{ phase.startAt|date('d/m/Y H:i') }}
                                    {% if phase.endAt %} - {{ phase.endAt|date('d/m/Y H:i') }}{% endif %}
                                    {% if phase.serverCount > 0 %}
                                        <span class="ml-3">{{ phase.serverCount }} serveur(s)</span>
                                    {% endif %}
                                </div>
                            </div>

                            {% if phaseRankings[phase.id] is defined %}
                                {% if phaseRankings[phase.id].individual is not empty %}
                                    <div class="mb-8">
                                        <h3 class="text-lg font-semibold mb-4">{{ 'championship.individual_ranking'|trans({}, 'championship') }}</h3>
                                        {% include 'championship/_ranking_individual.html.twig' with {ranking: phaseRankings[phase.id].individual} %}
                                    </div>
                                {% endif %}

                                {% if phaseRankings[phase.id].team is not empty %}
                                    <div>
                                        <h3 class="text-lg font-semibold mb-4">{{ 'championship.team_ranking'|trans({}, 'championship') }}</h3>
                                        {% include 'championship/_ranking_team.html.twig' with {ranking: phaseRankings[phase.id].team} %}
                                    </div>
                                {% endif %}

                                {% if phaseRankings[phase.id].individual is empty and phaseRankings[phase.id].team is empty %}
                                    <p class="text-gray-mid text-center py-8">{{ 'championship.no_results'|trans({}, 'championship') }}</p>
                                {% endif %}
                            {% else %}
                                <p class="text-gray-mid text-center py-8">{{ 'championship.no_results_yet'|trans({}, 'championship') }}</p>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}

            {# Maps content #}
            <div class="tab-content hidden" data-tab="maps">
                {% if round.maps is empty %}
                    <div class="bg-bg-card rounded-lg p-8 border border-metal-dark text-center">
                        <p class="text-gray-mid">{{ 'championship.no_maps'|trans({}, 'championship') }}</p>
                    </div>
                {% else %}
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        {% for map in round.maps %}
                            <a href="{{ map.uid ? path('app_championship_map_show', {uid: map.uid}) : '#' }}" class="block bg-bg-card rounded-lg border border-metal-dark overflow-hidden hover:border-turquoise/50 transition-colors {{ map.uid ? 'cursor-pointer' : 'cursor-default' }}">
                                <div class="p-4">
                                    {# Header with environment #}
                                    <div class="flex items-center justify-between gap-2 mb-3">
                                        {% if map.isSurprise %}
                                            <span class="px-2 py-0.5 bg-purple-500/20 text-purple-400 text-xs rounded uppercase">{{ 'championship.surprise'|trans({}, 'championship') }}</span>
                                        {% else %}
                                            <span></span>
                                        {% endif %}
                                        {% if map.environment %}
                                            <span class="px-2 py-0.5 bg-metal-dark text-gray-light text-xs rounded">{{ map.environment }}</span>
                                        {% endif %}
                                    </div>

                                    {# Content with name/author on left and thumbnail on right #}
                                    <div class="flex gap-4">
                                        <div class="flex-1 min-w-0">
                                            <h3 class="font-semibold text-white mb-2 tm-colors truncate">
                                                {% if map.isSurprise and not map.name %}
                                                    <span class="text-purple-400">???</span>
                                                {% else %}
                                                    {{ map.name|tm_color|raw }}
                                                {% endif %}
                                            </h3>

                                            {% if map.author and not map.isSurprise %}
                                                <p class="text-sm text-gray-light">
                                                    {{ 'championship.map_author'|trans({}, 'championship') }} <span class="tm-colors">{{ map.author|tm_color|raw }}</span>
                                                </p>
                                            {% endif %}
                                        </div>

                                        {# Thumbnail #}
                                        {% if map.thumbnailPath and not map.isSurprise %}
                                            <div class="flex-shrink-0">
                                                <img src="{{ asset('uploads/maps/thumbnails/' ~ map.thumbnailPath) }}" alt="{{ map.name }}" class="w-24 h-16 object-cover rounded border border-metal-dark">
                                            </div>
                                        {% endif %}
                                    </div>

                                    {# Records section #}
                                    {% if not map.isSurprise %}
                                        {% set records = map.uid and mapRecords[map.uid] is defined ? mapRecords[map.uid] : [] %}
                                        <div class="mt-3 pt-3 border-t border-metal-dark">
                                            <p class="text-xs text-gray-mid mb-2 uppercase">{{ 'championship.records'|trans({}, 'championship') }}</p>
                                            <div class="space-y-1">
                                                {% for laps in [1, 5, 10] %}
                                                    {% set recordData = null %}
                                                    {% for r in records %}
                                                        {% if r.record.laps == laps %}
                                                            {% set recordData = r %}
                                                        {% endif %}
                                                    {% endfor %}
                                                    <div class="flex items-baseline justify-between text-xs gap-2">
                                                        <span class="text-gray-light whitespace-nowrap">{{ ('championship.record.' ~ laps ~ '_laps')|trans({}, 'championship') }}</span>
                                                        <span class="whitespace-nowrap">
                                                            {% if recordData %}
                                                                <span class="text-turquoise font-mono">{{ recordData.record.formatTime }}</span>
                                                                <span class="text-gray-mid">{{ 'championship.record.by'|trans({}, 'championship') }}</span>
                                                                <span class="tm-colors">{{ (recordData.playerPseudo ?? recordData.record.playerLogin)|tm_color|raw }}</span>
                                                            {% else %}
                                                                <span class="text-gray-mid font-mono">--:--.---</span>
                                                            {% endif %}
                                                        </span>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% else %}
            <div class="bg-bg-card rounded-lg p-8 border border-metal-dark text-center">
                <p class="text-gray-mid">{{ 'championship.no_phases'|trans({}, 'championship') }}</p>
            </div>
        {% endif %}
    </section>

    <script>
        document.querySelectorAll('.round-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                const tabId = tab.dataset.tab;

                // Update tabs
                document.querySelectorAll('.round-tab').forEach(t => {
                    t.classList.remove('active', 'bg-orange', 'text-white', 'shadow-[0_2px_10px_rgba(255,140,0,0.4)]');
                    t.classList.add('bg-bg-card', 'text-gray-light', 'hover:text-white', 'hover:bg-metal-dark');
                });
                tab.classList.remove('bg-bg-card', 'text-gray-light', 'hover:text-white', 'hover:bg-metal-dark');
                tab.classList.add('active', 'bg-orange', 'text-white', 'shadow-[0_2px_10px_rgba(255,140,0,0.4)]');

                // Update content
                document.querySelectorAll('.tab-content').forEach(content => {
                    content.classList.add('hidden');
                });
                document.querySelector(`.tab-content[data-tab="${tabId}"]`).classList.remove('hidden');
            });
        });
    </script>
{% endblock %}
