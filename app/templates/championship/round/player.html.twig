{% extends 'championship/round/_layout.html.twig' %}

{% set activeTab = '' %}

{% block tab_content %}
    <div class="mb-6">
        <a href="{{ path('app_championship_round_phase', {id: round.id, phaseId: round.phases|first.id}) }}" class="text-gray-mid hover:text-turquoise transition-colors">
            &larr; {{ 'championship.back_to_ranking'|trans({}, 'championship') }}
        </a>
    </div>

    {# Player summary card #}
    <div class="bg-bg-card rounded-lg p-6 border border-metal-dark mb-6">
        <div class="flex flex-wrap items-start justify-between gap-6">
            {# Player info #}
            <div>
                <h2 class="font-russo text-2xl text-orange mb-2 tm-colors">{{ targetPlayer.pseudo|tm_color|raw }}</h2>
                {% if registration and registration.team %}
                    <p class="text-gray-light tm-colors">{{ registration.team.tag|tm_color|raw }}</p>
                {% endif %}
            </div>

            {# Ranking summary #}
            {% if playerRankingData %}
                <div class="flex flex-wrap gap-6">
                    <div class="text-center">
                        <div class="text-3xl font-russo {{ playerRankingData.position <= 3 ? 'text-orange' : 'text-white' }}">
                            #{{ playerRankingData.position }}
                        </div>
                        <div class="text-xs text-gray-mid uppercase">{{ 'championship.position'|trans({}, 'championship') }}</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-mono text-white">{{ playerRankingData.total }}</div>
                        <div class="text-xs text-gray-mid uppercase">{{ 'championship.total'|trans({}, 'championship') }}</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-mono text-gray-light">{{ playerRankingData.points }}</div>
                        <div class="text-xs text-gray-mid uppercase">{{ 'championship.points'|trans({}, 'championship') }}</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-mono text-turquoise">+{{ playerRankingData.bonus }}</div>
                        <div class="text-xs text-gray-mid uppercase">{{ 'championship.bonus'|trans({}, 'championship') }}</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-mono text-gray-light">{{ playerRankingData.nbMaps }}</div>
                        <div class="text-xs text-gray-mid uppercase">{{ 'championship.maps'|trans({}, 'championship') }}</div>
                    </div>
                </div>
            {% endif %}

            {# Availability #}
            {% if registration %}
                <div class="flex flex-col gap-2">
                    <div class="text-xs text-gray-mid uppercase mb-1">{{ 'championship.player_availability'|trans({}, 'championship') }}</div>
                    <div class="flex gap-3 text-sm">
                        <span class="{{ registration.availableSemiFinal1 ? 'text-green-400' : 'text-red-400 line-through' }}">
                            {{ 'championship.available_semi_final_1'|trans({}, 'championship') }}
                        </span>
                        <span class="{{ registration.availableSemiFinal2 ? 'text-green-400' : 'text-red-400 line-through' }}">
                            {{ 'championship.available_semi_final_2'|trans({}, 'championship') }}
                        </span>
                        <span class="{{ registration.availableFinal ? 'text-green-400' : 'text-red-400 line-through' }}">
                            {{ 'championship.available_final'|trans({}, 'championship') }}
                        </span>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

    {# Maps with player records #}
    {% if round.maps is empty %}
        <div class="bg-bg-card rounded-lg p-8 border border-metal-dark text-center">
            <p class="text-gray-mid">{{ 'championship.no_maps'|trans({}, 'championship') }}</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for map in round.maps %}
                <div class="block bg-bg-card rounded-lg border border-metal-dark overflow-hidden">
                    <div class="p-4">
                        {# Header with environment #}
                        <div class="flex items-center justify-between gap-2 mb-3">
                            {% if map.isSurprise %}
                                <span class="px-2 py-0.5 bg-purple-500/20 text-purple-400 text-xs rounded uppercase">{{ 'championship.surprise'|trans({}, 'championship') }}</span>
                            {% else %}
                                <span></span>
                            {% endif %}
                            {% if map.environment %}
                                <span class="px-2 py-0.5 bg-metal-dark text-gray-light text-xs rounded">{{ map.environment }}</span>
                            {% endif %}
                        </div>

                        {# Content with name/author on left and thumbnail on right #}
                        <div class="flex gap-4">
                            <div class="flex-1 min-w-0">
                                <h3 class="font-semibold text-white mb-2 tm-colors truncate">
                                    {% if map.isSurprise and not map.name %}
                                        <span class="text-purple-400">???</span>
                                    {% else %}
                                        {{ map.name|tm_color|raw }}
                                    {% endif %}
                                </h3>

                                {% if map.author and (not map.isSurprise or map.uid) %}
                                    <p class="text-sm text-gray-light">
                                        {{ 'championship.map_author'|trans({}, 'championship') }} <span class="tm-colors">{{ map.author|tm_color|raw }}</span>
                                    </p>
                                {% endif %}
                            </div>

                            {# Thumbnail #}
                            {% if map.thumbnailPath and (not map.isSurprise or map.uid) %}
                                <div class="flex-shrink-0">
                                    <img src="{{ asset('uploads/maps/thumbnails/' ~ map.thumbnailPath) }}" alt="{{ map.name }}" class="w-24 h-16 object-cover rounded border border-metal-dark">
                                </div>
                            {% endif %}
                        </div>

                        {# Player records section #}
                        {% if not map.isSurprise or map.uid %}
                            {% set records = map.uid and playerRecords[map.uid] is defined ? playerRecords[map.uid] : [] %}
                            <div class="mt-3 pt-3 border-t border-metal-dark">
                                <p class="text-xs text-gray-mid mb-2 uppercase">{{ 'championship.records'|trans({}, 'championship') }}</p>
                                <div class="space-y-2">
                                    {% for laps in map.isSurprise ? [1, 10] : [1, 5, 10] %}
                                        {% set recordData = records[laps] is defined ? records[laps] : null %}
                                        <div class="flex items-baseline justify-between text-xs gap-2">
                                            <span class="text-gray-light whitespace-nowrap">{{ 'championship.record.laps'|trans({'%count%': laps}, 'championship') }}</span>
                                            <span class="whitespace-nowrap">
                                                {% if recordData %}
                                                    <span class="inline-flex items-center gap-2">
                                                        <span class="{{ recordData.position == 1 ? 'text-orange' : 'text-gray-mid' }} font-semibold">#{{ recordData.position }}</span>
                                                        <span class="text-turquoise font-mono">{{ recordData.record.formatTime }}</span>
                                                        {% if recordData.diff > 0 %}
                                                            <span class="text-red-400 font-mono text-[10px]">+{{ (recordData.diff / 1000)|number_format(2, '.', '') }}s</span>
                                                        {% endif %}
                                                    </span>
                                                {% else %}
                                                    <span class="text-gray-mid font-mono">--:--.--</span>
                                                {% endif %}
                                            </span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
