{% extends 'championship/round/_layout.html.twig' %}

{% set activeTab = 'maps' %}

{% block tab_content %}
    {% if round.maps is empty %}
        <div class="bg-bg-card rounded-lg p-8 border border-metal-dark text-center">
            <p class="text-gray-mid">{{ 'championship.no_maps'|trans({}, 'championship') }}</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for map in round.maps %}
                <a href="{{ map.uid ? path('app_championship_map_show', {uid: map.uid}) : '#' }}" class="block bg-bg-card rounded-lg border border-metal-dark overflow-hidden hover:border-turquoise/50 transition-colors {{ map.uid ? 'cursor-pointer' : 'cursor-default' }}">
                    <div class="p-4">
                        {# Header with environment #}
                        <div class="flex items-center justify-between gap-2 mb-3">
                            {% if map.isSurprise %}
                                <span class="px-2 py-0.5 bg-purple-500/20 text-purple-400 text-xs rounded uppercase">{{ 'championship.surprise'|trans({}, 'championship') }}</span>
                            {% else %}
                                <span></span>
                            {% endif %}
                            {% if map.environment %}
                                <span class="px-2 py-0.5 bg-metal-dark text-gray-light text-xs rounded">{{ map.environment }}</span>
                            {% endif %}
                        </div>

                        {# Content with name/author on left and thumbnail on right #}
                        <div class="flex gap-4">
                            <div class="flex-1 min-w-0">
                                <h3 class="font-semibold text-white mb-2 tm-colors truncate">
                                    {% if map.isSurprise and not map.name %}
                                        <span class="text-purple-400">???</span>
                                    {% else %}
                                        {{ map.name|tm_color|raw }}
                                    {% endif %}
                                </h3>

                                {% if map.author and (not map.isSurprise or map.uid) %}
                                    <p class="text-sm text-gray-light">
                                        {{ 'championship.map_author'|trans({}, 'championship') }} <span class="tm-colors">{{ map.author|tm_color|raw }}</span>
                                    </p>
                                {% endif %}
                            </div>

                            {# Thumbnail #}
                            {% if map.thumbnailPath and (not map.isSurprise or map.uid) %}
                                <div class="flex-shrink-0">
                                    <img src="{{ asset('uploads/maps/thumbnails/' ~ map.thumbnailPath) }}" alt="{{ map.name }}" class="w-24 h-16 object-cover rounded border border-metal-dark">
                                </div>
                            {% endif %}
                        </div>

                        {# Records section #}
                        {% if not map.isSurprise or map.uid %}
                            {% set records = map.uid and mapRecords[map.uid] is defined ? mapRecords[map.uid] : [] %}
                            <div class="mt-3 pt-3 border-t border-metal-dark">
                                <p class="text-xs text-gray-mid mb-2 uppercase">{{ 'championship.records'|trans({}, 'championship') }}</p>
                                <div class="space-y-1">
                                    {% for laps in map.isSurprise ? [1, 10] : [1, 5, 10] %}
                                        {% set recordData = null %}
                                        {% for r in records %}
                                            {% if r.record.laps == laps and recordData is null %}
                                                {% set recordData = r %}
                                            {% endif %}
                                        {% endfor %}
                                        <div class="flex items-baseline justify-between text-xs gap-2">
                                            <span class="text-gray-light whitespace-nowrap">{{ 'championship.record.laps'|trans({'%count%': laps}, 'championship') }}</span>
                                            <span class="whitespace-nowrap">
                                                {% if recordData %}
                                                    <span class="text-turquoise font-mono">{{ recordData.record.formatTime }}</span>
                                                    <span class="text-gray-mid">{{ 'championship.record.by'|trans({}, 'championship') }}</span>
                                                    <span class="tm-colors">{{ (recordData.playerPseudo ?? recordData.record.playerLogin)|tm_color|raw }}</span>
                                                {% else %}
                                                    <span class="text-gray-mid font-mono">--:--.--</span>
                                                {% endif %}
                                            </span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
