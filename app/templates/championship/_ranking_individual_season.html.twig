{# Individual season ranking #}
{% if ranking is empty %}
    <p class="text-gray-mid">{{ 'championship.no_ranking'|trans({}, 'championship') }}</p>
{% else %}
    {% set cols = '2.5rem 1fr 1fr' %}
    {% for round in rounds %}{% set cols = cols ~ ' 4rem' %}{% endfor %}
    {% set cols = cols ~ ' 3.5rem' %}
    <div class="overflow-x-auto">
        {# Header #}
        <div class="grid gap-x-2 text-xs text-gray-light uppercase border-b border-metal-dark pb-2 mb-2" style="grid-template-columns: {{ cols }};">
            <span class="px-2">#</span>
            <span>{{ 'championship.player'|trans({}, 'championship') }}</span>
            <span>{{ 'championship.team'|trans({}, 'championship') }}</span>
            {% for round in rounds %}
                <span class="text-center">{{ round.name }}</span>
            {% endfor %}
            <span class="text-right">{{ 'championship.total'|trans({}, 'championship') }}</span>
        </div>
        {# Rows #}
        {% for item in ranking %}
            {% set isCurrentPlayer = player is defined and player and item.entity.login|lower == player.login|lower %}
            <div class="grid gap-x-2 py-2 border-b border-metal-dark/50 last:border-0 text-sm rounded {{ isCurrentPlayer ? 'border-l-4 border-l-turquoise' : '' }}" style="grid-template-columns: {{ cols }};">
                <span class="px-2 font-semibold {{ item.position <= 3 ? 'text-orange' : 'text-gray-mid' }}">{{ item.position }}</span>
                <span class="tm-colors truncate">{{ item.entity.pseudo|tm_color|raw }}</span>
                <span class="text-gray-light tm-colors truncate">{{ item.entity.hasTeam ? item.entity.team.fullName|tm_color|raw : 'No Team' }}</span>
                {% for round in rounds %}
                    <span class="text-center">
                        {% if item.roundScores[round.id] is defined %}
                            {{ item.roundScores[round.id] }}
                        {% else %}
                            <span class="text-gray-mid">-</span>
                        {% endif %}
                    </span>
                {% endfor %}
                <span class="text-right font-semibold text-turquoise">{{ item.totalPoints }}</span>
            </div>
        {% endfor %}
    </div>
{% endif %}
