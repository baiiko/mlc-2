{% extends 'base.html.twig' %}

{% block title %}{{ 'title.create'|trans({}, 'team') }}{% endblock %}

{% form_theme form 'register/_form_theme.html.twig' %}

{% block body %}
    <section class="max-w-[1400px] mx-auto px-10 py-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
            {# Formulaire #}
            <div>
                <h1 class="font-russo text-4xl mb-2">{{ 'create.title'|trans({}, 'team') }}</h1>
                <p class="text-gray-light mb-8">{{ 'create.subtitle'|trans({}, 'team') }}</p>

                {% if form.vars.errors|length > 0 %}
                    <div class="bg-red-500/20 border border-red-500 rounded-lg p-4 mb-6">
                        {% for error in form.vars.errors %}
                            <p class="text-red-400">{{ error.message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                {{ form_start(form, {'attr': {'class': 'space-y-2', 'autocomplete': 'off'}}) }}
                    {# Informations de l'équipe #}
                    <div class="bg-bg-card rounded-lg p-6 border border-metal-dark mb-6">
                        <h2 class="font-russo text-xl text-orange mb-6">{{ 'create.team_info'|trans({}, 'team') }}</h2>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {{ form_row(form.tag) }}
                            {{ form_row(form.fullName) }}
                        </div>
                    </div>

                    {# Submit #}
                    <div class="flex gap-4">
                        <button type="submit" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-gradient-to-br from-orange to-orange-dark text-white shadow-[0_4px_15px_rgba(255,140,0,0.4)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(255,140,0,0.5)]">
                            {{ 'create.submit'|trans({}, 'team') }}
                        </button>

                        <a href="{{ path('app_profile') }}" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-transparent text-white border-2 border-metal-light hover:border-turquoise hover:text-turquoise">
                            {{ 'buttons.cancel'|trans({}, 'common') }}
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>

            {# Sidebar infos #}
            <div class="lg:sticky lg:top-24">
                <div class="bg-bg-card rounded-lg p-6 border border-metal-dark mb-6">
                    <h3 class="font-russo text-xl mb-4">{{ 'create.why_create'|trans({}, 'team') }}</h3>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <span class="text-2xl">👥</span>
                            <div>
                                <div class="font-semibold">{{ 'create.play_together'|trans({}, 'team') }}</div>
                                <div class="text-sm text-gray-mid">{{ 'create.play_together_desc'|trans({}, 'team') }}</div>
                            </div>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-2xl">🏆</span>
                            <div>
                                <div class="font-semibold">{{ 'create.team_ranking'|trans({}, 'team') }}</div>
                                <div class="text-sm text-gray-mid">{{ 'create.team_ranking_desc'|trans({}, 'team') }}</div>
                            </div>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-2xl">🎯</span>
                            <div>
                                <div class="font-semibold">{{ 'create.visual_identity'|trans({}, 'team') }}</div>
                                <div class="text-sm text-gray-mid">{{ 'create.visual_identity_desc'|trans({}, 'team') }}</div>
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="bg-gradient-to-br from-turquoise/20 to-orange/20 rounded-lg p-6 border border-turquoise/30">
                    <h3 class="font-russo text-xl mb-2">{{ 'create.tips'|trans({}, 'team') }}</h3>
                    <ul class="text-gray-light text-sm space-y-2">
                        <li>• {{ 'create.tip_tag'|trans({}, 'team') }}</li>
                        <li>• {{ 'create.tip_fullname'|trans({}, 'team') }}</li>
                        <li>• {{ 'create.tip_member'|trans({}, 'team') }}</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
