{% extends 'base.html.twig' %}

{% block title %}{{ 'title.join'|trans({}, 'team') }}{% endblock %}

{% block body %}
    <section class="max-w-[1400px] mx-auto px-10 py-16">
        <div class="mb-8">
            <h1 class="font-russo text-4xl mb-2">{{ 'join.title'|trans({}, 'team') }}</h1>
            <p class="text-gray-light">{{ 'join.subtitle'|trans({}, 'team') }}</p>
        </div>

        {% if pendingRequest %}
            <div class="bg-turquoise/20 border border-turquoise rounded-lg p-6 mb-8">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="font-russo text-xl text-turquoise mb-2">{{ 'join.pending_request'|trans({}, 'team') }}</h3>
                        <p class="text-gray-light">
                            {{ 'join.pending_description'|trans({'%team%': pendingRequest.team.tag}, 'team') }}
                            ({{ pendingRequest.team.fullName }})
                        </p>
                        <p class="text-sm text-gray-mid mt-1">
                            {{ 'join.sent_on'|trans({}, 'team') }} {{ pendingRequest.createdAt|date('d/m/Y') }} {{ 'dates.at'|trans({}, 'common') }} {{ pendingRequest.createdAt|date('H:i') }}
                        </p>
                    </div>
                    <form action="{{ path('app_team_join_cancel') }}" method="post">
                        <button type="submit" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium uppercase tracking-wider rounded transition-all duration-300 no-underline bg-transparent text-red-400 border border-red-400 hover:bg-red-400/10">
                            {{ 'join.cancel'|trans({}, 'team') }}
                        </button>
                    </form>
                </div>
            </div>
        {% endif %}

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for team in teams %}
                <div class="bg-bg-card rounded-lg p-6 border border-metal-dark hover:border-orange transition-colors">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="text-3xl">👥</span>
                        <div>
                            <div class="font-russo text-xl text-orange">{{ team.tag }}</div>
                            <div class="text-white">{{ team.fullName }}</div>
                        </div>
                    </div>

                    <div class="text-sm text-gray-mid mb-4">
                        {{ 'members.count'|trans({'%count%': team.activeMembers|length}, 'team') }}
                    </div>

                    {% if pendingRequest and pendingRequest.team.id == team.id %}
                        <div class="text-center text-turquoise text-sm font-medium py-2">
                            {{ 'join.request_sent'|trans({}, 'team') }}
                        </div>
                    {% else %}
                        <form action="{{ path('app_team_join_submit', {id: team.id}) }}" method="post">
                            <button type="submit" class="w-full inline-flex items-center justify-center px-4 py-2 text-sm font-medium uppercase tracking-wider rounded transition-all duration-300 no-underline bg-gradient-to-br from-turquoise to-turquoise-dark text-white hover:-translate-y-0.5">
                                {{ 'join.request_join'|trans({}, 'team') }}
                            </button>
                        </form>
                    {% endif %}
                </div>
            {% endfor %}

            {# Card pour créer une équipe #}
            {% if not pendingRequest %}
                <a href="{{ path('app_team_create') }}" class="bg-bg-card rounded-lg p-6 border-2 border-dashed border-metal-light hover:border-orange transition-colors flex flex-col items-center justify-center min-h-[200px] no-underline group">
                    <span class="text-6xl text-metal-light group-hover:text-orange transition-colors mb-4">+</span>
                    <span class="text-gray-light group-hover:text-white transition-colors font-medium uppercase tracking-wider text-sm">{{ 'join.create_team'|trans({}, 'team') }}</span>
                </a>
            {% endif %}
        </div>

        <div class="mt-8">
            <a href="{{ path('app_profile') }}" class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium uppercase tracking-wider rounded transition-all duration-300 no-underline bg-transparent text-white border border-metal-light hover:border-turquoise hover:text-turquoise">
                {{ 'join.back_to_profile'|trans({}, 'team') }}
            </a>
        </div>
    </section>
{% endblock %}
