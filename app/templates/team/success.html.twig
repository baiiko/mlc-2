{% extends 'base.html.twig' %}

{% block title %}Équipe créée - MLC ModLap Championship{% endblock %}

{% block body %}
    <section class="max-w-[800px] mx-auto px-10 py-16">
        <div class="bg-bg-card rounded-lg p-8 border border-metal-dark text-center">
            <div class="text-6xl mb-6">🎉</div>

            <h1 class="font-russo text-4xl mb-4 text-turquoise">Équipe créée !</h1>

            <p class="text-gray-light text-lg mb-8">
                Votre équipe <span class="text-orange font-semibold">{{ team.tag }} - {{ team.fullName }}</span> a été créée avec succès.
            </p>

            <div class="bg-metal-dark rounded-lg p-6 mb-8">
                <h2 class="font-russo text-xl mb-4">Récapitulatif</h2>
                <div class="grid grid-cols-2 gap-4 text-left">
                    <div>
                        <span class="text-gray-mid text-sm">Tag</span>
                        <p class="text-white font-semibold">{{ team.tag }}</p>
                    </div>
                    <div>
                        <span class="text-gray-mid text-sm">Nom complet</span>
                        <p class="text-white font-semibold">{{ team.fullName }}</p>
                    </div>
                </div>
            </div>

            <div class="flex justify-center gap-4">
                <a href="{{ path('app_profile') }}" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-gradient-to-br from-orange to-orange-dark text-white shadow-[0_4px_15px_rgba(255,140,0,0.4)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(255,140,0,0.5)]">
                    Voir mon profil
                </a>

                <a href="{{ path('app_home') }}" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-transparent text-white border-2 border-metal-light hover:border-turquoise hover:text-turquoise">
                    Retour à l'accueil
                </a>
            </div>
        </div>
    </section>
{% endblock %}
