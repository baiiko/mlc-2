{% extends 'base.html.twig' %}

{% block title %}{{ 'title.requests'|trans({}, 'team') }}{% endblock %}

{% block body %}
    <section class="max-w-[1400px] mx-auto px-10 py-16">
        <div class="mb-8">
            <h1 class="font-russo text-4xl mb-2">{{ 'requests.title'|trans({}, 'team') }}</h1>
            <p class="text-gray-light">{{ 'requests.subtitle'|trans({'%team%': team.tag}, 'team') }}</p>
        </div>

        {% if requests|length > 0 %}
            <div class="space-y-4">
                {% for request in requests %}
                    <div class="bg-bg-card rounded-lg p-6 border border-metal-dark">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <span class="text-3xl">👤</span>
                                <div>
                                    <div class="font-russo text-xl text-white">{{ request.player.displayName|tm_color }}</div>
                                    <p class="text-sm text-gray-mid">
                                        {{ 'requests.request_sent_on'|trans({}, 'team') }} {{ request.createdAt|date('d/m/Y') }} {{ 'dates.at'|trans({}, 'common') }} {{ request.createdAt|date('H:i') }}
                                    </p>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                <form action="{{ path('app_team_request_accept', {id: request.id}) }}" method="post">
                                    <button type="submit" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium uppercase tracking-wider rounded transition-all duration-300 no-underline bg-gradient-to-br from-green-500 to-green-600 text-white hover:-translate-y-0.5">
                                        {{ 'requests.accept'|trans({}, 'team') }}
                                    </button>
                                </form>
                                <form action="{{ path('app_team_request_reject', {id: request.id}) }}" method="post">
                                    <button type="submit" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium uppercase tracking-wider rounded transition-all duration-300 no-underline bg-transparent text-red-400 border border-red-400 hover:bg-red-400/10">
                                        {{ 'requests.reject'|trans({}, 'team') }}
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="bg-bg-card rounded-lg p-8 border border-metal-dark text-center">
                <span class="text-4xl mb-4 block">📭</span>
                <p class="text-gray-light">{{ 'requests.no_requests'|trans({}, 'team') }}</p>
            </div>
        {% endif %}

        <div class="mt-8">
            <a href="{{ path('app_team_edit') }}" class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium uppercase tracking-wider rounded transition-all duration-300 no-underline bg-transparent text-white border border-metal-light hover:border-turquoise hover:text-turquoise">
                {{ 'requests.back_to_edit'|trans({}, 'team') }}
            </a>
        </div>
    </section>
{% endblock %}
