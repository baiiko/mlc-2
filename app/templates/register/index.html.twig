{% extends 'base.html.twig' %}

{% block title %}{{ 'title.register'|trans({}, 'player') }}{% endblock %}

{% form_theme form 'register/_form_theme.html.twig' %}

{% block body %}
    <section class="max-w-[1400px] mx-auto px-10 py-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
            {# Formulaire #}
            <div>
                <h1 class="font-russo text-4xl mb-2">{{ 'register.title'|trans({}, 'player') }}</h1>
                <p class="text-gray-light mb-8">{{ 'register.subtitle'|trans({}, 'player') }}</p>

                {% if form.vars.errors|length > 0 %}
                    <div class="bg-red-500/20 border border-red-500 rounded-lg p-4 mb-6">
                        {% for error in form.vars.errors %}
                            <p class="text-red-400">{{ error.message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                {{ form_start(form, {'attr': {'class': 'space-y-2', 'autocomplete': 'off'}}) }}
                    {# Informations personnelles #}
                    <div class="bg-bg-card rounded-lg p-6 border border-metal-dark mb-6">
                        <h2 class="font-russo text-xl text-orange mb-6">{{ 'register.personal_info'|trans({}, 'player') }}</h2>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {{ form_row(form.login, {'icon': '🎮'}) }}
                            {{ form_row(form.pseudo, {'icon': '👤'}) }}
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {{ form_row(form.email, {'icon': '✉️'}) }}
                            {{ form_row(form.discord, {'icon': '💬', 'help': 'form.discord_help'|trans({}, 'player')}) }}
                        </div>
                    </div>

                    {# Conditions #}
                    <div class="bg-bg-card rounded-lg p-6 border border-metal-dark mb-6">
                        <h2 class="font-russo text-xl text-orange mb-6">{{ 'register.conditions'|trans({}, 'player') }}</h2>

                        {{ form_row(form.rulesAccepted) }}
                        {{ form_row(form.newsletter) }}
                    </div>

                    {# Submit #}
                    <div class="flex gap-4">
                        <button type="submit" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-gradient-to-br from-orange to-orange-dark text-white shadow-[0_4px_15px_rgba(255,140,0,0.4)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(255,140,0,0.5)]">
                            {{ 'register.submit'|trans({}, 'player') }}
                        </button>

                        <a href="{{ path('app_home') }}" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-transparent text-white border-2 border-metal-light hover:border-turquoise hover:text-turquoise">
                            {{ 'buttons.cancel'|trans({}, 'common') }}
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>

            {# Sidebar infos #}
            <div class="lg:sticky lg:top-24">
                <div class="bg-bg-card rounded-lg p-6 border border-metal-dark mb-6">
                    <h3 class="font-russo text-xl mb-4">{{ 'register.why_join'|trans({}, 'player') }}</h3>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <span class="text-2xl">🏆</span>
                            <div>
                                <div class="font-semibold">{{ 'register.regular_competition'|trans({}, 'player') }}</div>
                            </div>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-2xl">👥</span>
                            <div>
                                <div class="font-semibold">{{ 'register.active_community'|trans({}, 'player') }}</div>
                            </div>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-2xl">📊</span>
                            <div>
                                <div class="font-semibold">{{ 'register.realtime_ranking'|trans({}, 'player') }}</div>
                                <div class="text-sm text-gray-mid">{{ 'register.track_progress'|trans({}, 'player') }}</div>
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="bg-gradient-to-br from-orange/20 to-turquoise/20 rounded-lg p-6 border border-orange/30">
                    <h3 class="font-russo text-xl mb-2">Saison 13</h3>
                    <p class="text-gray-light text-sm mb-4">
                        {{ 'register.season_info'|trans({}, 'player') }}
                    </p>
                    <div class="flex items-center gap-2 text-turquoise font-semibold">
                        <span>🗓️</span>
                        <span>{{ 'register.season_start'|trans({}, 'player') }}</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
