{% extends 'base.html.twig' %}

{% block title %}{{ 'title.password_changed'|trans({}, 'player') }}{% endblock %}

{% block body %}
    <section class="max-w-[500px] mx-auto px-10 py-16">
        <div class="bg-bg-card rounded-lg p-8 border border-metal-dark">
            <div class="text-center">
                <div class="text-5xl mb-4">✅</div>
                <h1 class="font-russo text-3xl mb-4 text-turquoise">{{ 'reset_password_success.title'|trans({}, 'player') }}</h1>
                <p class="text-gray-light mb-8">
                    {{ 'reset_password_success.message'|trans({}, 'player') }}
                </p>

                <a href="{{ path('app_login') }}" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-gradient-to-br from-orange to-orange-dark text-white shadow-[0_4px_15px_rgba(255,140,0,0.4)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(255,140,0,0.5)]">
                    {{ 'login.submit'|trans({}, 'player') }}
                </a>
            </div>
        </div>
    </section>
{% endblock %}
