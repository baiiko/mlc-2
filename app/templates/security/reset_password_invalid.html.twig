{% extends 'base.html.twig' %}

{% block title %}{{ 'title.invalid_link'|trans({}, 'player') }}{% endblock %}

{% block body %}
    <section class="max-w-[500px] mx-auto px-10 py-16">
        <div class="bg-bg-card rounded-lg p-8 border border-metal-dark">
            <div class="text-center">
                <div class="text-5xl mb-4">⚠️</div>
                <h1 class="font-russo text-3xl mb-4 text-red-400">{{ 'reset_password_invalid.title'|trans({}, 'player') }}</h1>
                <p class="text-gray-light mb-8">
                    {{ 'reset_password_invalid.message'|trans({}, 'player') }}
                </p>

                <div class="flex flex-col gap-4">
                    <a href="{{ path('app_forgot_password') }}" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-gradient-to-br from-orange to-orange-dark text-white shadow-[0_4px_15px_rgba(255,140,0,0.4)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(255,140,0,0.5)]">
                        {{ 'reset_password_invalid.request_new'|trans({}, 'player') }}
                    </a>
                    <a href="{{ path('app_login') }}" class="text-orange hover:text-turquoise transition-colors">
                        {{ 'forgot_password.back_to_login'|trans({}, 'player') }}
                    </a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
