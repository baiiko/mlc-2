<footer class="bg-metal-dark border-t-[3px] border-t-orange mt-20">
    <div class="max-w-[1400px] mx-auto px-10 py-16 grid grid-cols-1 md:grid-cols-4 gap-10">
        {# Brand #}
        <div>
            <div class="font-russo text-3xl flex mb-4">
                <span class="text-orange">M</span>
                <span class="text-gray-light">L</span>
                <span class="text-turquoise">C</span>
            </div>
            <p class="text-gray-light text-sm leading-relaxed">
                ModLap Championship est une compétition TrackMania communautaire
                créée par des passionnés, pour des passionnés. Rejoignez-nous !
            </p>
        </div>

        {# Navigation #}
        <div>
            <h4 class="font-russo text-base text-orange mb-5">Navigation</h4>
            <ul class="space-y-2.5">
                <li><a href="{{ path('app_home') }}" class="text-gray-light text-sm no-underline hover:text-white transition-colors">Accueil</a></li>
                <li><a href="#" class="text-gray-light text-sm no-underline hover:text-white transition-colors">Classement</a></li>
                <li><a href="#" class="text-gray-light text-sm no-underline hover:text-white transition-colors">Calendrier</a></li>
                <li><a href="#" class="text-gray-light text-sm no-underline hover:text-white transition-colors">Règlement</a></li>
            </ul>
        </div>

        {# Communauté #}
        <div>
            <h4 class="font-russo text-base text-orange mb-5">Communauté</h4>
            <ul class="space-y-2.5">
                <li><a href="#" class="text-gray-light text-sm no-underline hover:text-white transition-colors">Discord</a></li>
                <li><a href="#" class="text-gray-light text-sm no-underline hover:text-white transition-colors">Twitch</a></li>
                <li><a href="#" class="text-gray-light text-sm no-underline hover:text-white transition-colors">Twitter</a></li>
                <li><a href="#" class="text-gray-light text-sm no-underline hover:text-white transition-colors">YouTube</a></li>
            </ul>
        </div>

        {# Réseaux sociaux #}
        <div>
            <h4 class="font-russo text-base text-orange mb-5">Nous suivre</h4>
            <div class="flex gap-2">
                {% set socials = [
                    { label: 'DC', href: '#' },
                    { label: 'TW', href: '#' },
                    { label: 'YT', href: '#' }
                ] %}
                {% for social in socials %}
                    <a href="{{ social.href }}"
                       class="w-10 h-10 rounded-full bg-metal-mid flex items-center justify-center
                              text-gray-light text-xs font-bold no-underline
                              hover:bg-orange hover:text-white transition-all">
                        {{ social.label }}
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Copyright #}
    <div class="border-t border-metal-mid py-6 text-center text-gray-mid text-sm">
        &copy; {{ "now"|date("Y") }} MLC - ModLap Championship. Tous droits réservés. |
        TrackMania est une marque de Ubisoft Nadeo.
    </div>
</footer>
