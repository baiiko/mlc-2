{% extends 'base.html.twig' %}

{% block title %}Lien invalide - MLC ModLap Championship{% endblock %}

{% block body %}
    <section class="max-w-[500px] mx-auto px-10 py-16">
        <div class="bg-bg-card rounded-lg p-8 border border-metal-dark text-center">
            <div class="text-6xl mb-6">❌</div>
            <h1 class="font-russo text-3xl mb-4">Lien invalide</h1>
            <p class="text-gray-light mb-8">
                Ce lien d'activation est invalide ou a expiré.<br>
                Les liens d'activation ne sont valables que 24 heures et ne peuvent être utilisés qu'une seule fois.
            </p>

            <div class="space-y-4">
                <a href="{{ path('app_register') }}" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-gradient-to-br from-orange to-orange-dark text-white shadow-[0_4px_15px_rgba(255,140,0,0.4)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(255,140,0,0.5)]">
                    S'inscrire à nouveau
                </a>
            </div>
        </div>
    </section>
{% endblock %}
