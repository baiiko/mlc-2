{% extends 'base.html.twig' %}

{% block title %}Compte activé - MLC ModLap Championship{% endblock %}

{% block body %}
    <section class="max-w-[500px] mx-auto px-10 py-16">
        <div class="bg-bg-card rounded-lg p-8 border border-metal-dark text-center">
            <div class="text-6xl mb-6">✅</div>
            <h1 class="font-russo text-3xl mb-4">Compte activé !</h1>
            <p class="text-gray-light mb-8">
                Ton mot de passe a été créé avec succès.<br>
                Tu peux maintenant te connecter avec ton login <span class="text-orange font-semibold">{{ player.login }}</span>.
            </p>

            <a href="{{ path('app_home') }}" class="inline-flex items-center justify-center px-8 py-4 font-semibold text-sm uppercase tracking-wider rounded transition-all duration-300 no-underline bg-gradient-to-br from-orange to-orange-dark text-white shadow-[0_4px_15px_rgba(255,140,0,0.4)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(255,140,0,0.5)]">
                Retour à l'accueil
            </a>
        </div>
    </section>
{% endblock %}
